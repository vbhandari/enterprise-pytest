# Application
APP_NAME="Order Management API"
DEBUG=false
ENVIRONMENT=development

# Database (default auto-resolves to <project_root>/sut/data/orders.db)
# DATABASE_URL=sqlite+aiosqlite:///path/to/orders.db
DATABASE_ECHO=false

# Auth / JWT
SECRET_KEY=change-this-to-a-real-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Tax
TAX_RATE=0.08

# Server
HOST=0.0.0.0
PORT=8000
